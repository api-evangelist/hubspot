          "name": "Hubspot List All Domains",
          "request": {
            "name": "Hubspot List All Domains",
            "description": {
              "content": "Returns all existing domains that have been created and connected to the HubSpot account.\nResults can be filtered by creation or update date and paginated using cursor-based pagination.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "cms",
                "v3",
                "domains",
                ""
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "createdAt",
                  "value": "<dateTime>",
                  "description": "Only return domains created at this exact date and time"
                },
                {
                  "disabled": false,
                  "key": "createdAfter",
                  "value": "<dateTime>",
                  "description": "Only return domains created after this date and time"
                },
                {
                  "disabled": false,
                  "key": "createdBefore",
                  "value": "<dateTime>",
                  "description": "Only return domains created before this date and time"
                },
                {
                  "disabled": false,
                  "key": "updatedAt",
                  "value": "<dateTime>",
                  "description": "Only return domains updated at this exact date and time"
                },
                {
                  "disabled": false,
                  "key": "updatedAfter",
                  "value": "<dateTime>",
                  "description": "Only return domains updated after this date and time"
                },
                {
                  "disabled": false,
                  "key": "updatedBefore",
                  "value": "<dateTime>",
                  "description": "Only return domains updated before this date and time"
                },
                {
                  "disabled": false,
                  "key": "sort",
