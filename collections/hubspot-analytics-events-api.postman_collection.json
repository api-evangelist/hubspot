{
  "item": [
    {
      "id": "96838b47-6f3e-41dd-9aff-32f1d40e9f67",
      "name": "Event Instances",
      "description": {
        "content": "Retrieve and query event completion data from CRM objects",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "9ee895e0-f1f5-4336-a220-ace7151b7b96",
          "name": "Hubspot Retrieve Event Instances",
          "request": {
            "name": "Hubspot Retrieve Event Instances",
            "description": {
              "content": "Retrieve instances of event completion data from your HubSpot account. \nUse this endpoint to query events associated with specific CRM objects, \nfilter by event type and date range, and paginate through large result sets. \nThis is useful for analyzing user engagement and tracking conversion funnels.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "events",
                "v3",
                "events"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "objectType",
                  "value": "<string>",
                  "description": "The type of CRM object to filter event instances on"
                },
                {
                  "disabled": false,
                  "key": "objectId",
                  "value": "<string>",
                  "description": "The ID of the CRM object to filter events. Requires objectType parameter."
                },
                {
                  "disabled": false,
                  "key": "eventType",
                  "value": "<string>",
                  "description": "Filter by specific event type name"
                },
                {
                  "disabled": false,
                  "key": "occurredAfter",
                  "value": "<dateTime>",
                  "description": "Filter for events that occurred after this ISO 8601 datetime"
                },
                {
                  "disabled": false,
                  "key": "occurredBefore",
                  "value": "<dateTime>",
                  "description": "Filter for events that occurred before this ISO 8601 datetime"
                },
                {
                  "disabled": false,
                  "key": "sort",
                  "value": "<string>",
                  "description": "Sort direction based on event timestamp"
                },
                {
                  "disabled": false,
                  "key": "limit",
                  "value": "20",
                  "description": "Maximum number of results per page (1-100)"
                },
                {
                  "disabled": false,
                  "key": "after",
                  "value": "<string>",
                  "description": "Pagination cursor for the next page of results"
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": {
              "type": "oauth2",
              "oauth2": [
                {
                  "key": "scope",
                  "value": "analytics.read"
                },
                {
                  "key": "accessTokenUrl",
                  "value": "https://api.hubapi.com/oauth/v1/token"
                },
                {
                  "key": "authUrl",
                  "value": "https://app.hubspot.com/oauth/authorize"
                },
                {
                  "key": "grant_type",
                  "value": "authorization_code"
                }
              ]
            }
          },
