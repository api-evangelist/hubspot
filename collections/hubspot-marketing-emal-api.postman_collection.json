      },
      "item": [
        {
          "id": "fec82c55-5e07-4573-bf69-e0c09b5992a5",
          "name": "Hubspot Send a Transactional Email",
          "request": {
            "name": "Hubspot Send a Transactional Email",
            "description": {
              "content": "Sends a single transactional email using a pre-defined email template.\nThe email is sent immediately to the specified recipient with the provided personalization tokens.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "marketing",
                "v3",
                "transactional",
                "single-email",
                "send"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": {
              "type": "oauth2",
              "oauth2": [
                {
                  "key": "scope",
                  "value": "transactional-email"
                },
                {
                  "key": "accessTokenUrl",
                  "value": "https://api.hubapi.com/oauth/v1/token"
                },
                {
                  "key": "authUrl",
                  "value": "https://app.hubspot.com/oauth/authorize"
                },
                {
                  "key": "grant_type",
                  "value": "authorization_code"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailId\": \"<integer>\",\n  \"message\": {\n    \"to\": \"<email>\",\n    \"from\": \"<email>\",\n    \"sendId\": \"<string>\",\n    \"replyTo\": [\n      \"<email>\",\n      \"<email>\"\n    ],\n    \"cc\": [\n      \"<email>\",\n      \"<email>\"\n    ],\n    \"bcc\": [\n      \"<email>\",\n      \"<email>\"\n    ]\n  },\n  \"contactProperties\": {\n    \"key_0\": \"<string>\",\n    \"key_1\": \"<string>\",\n    \"key_2\": \"<string>\",\n    \"key_3\": \"<string>\"\n  },\n  \"customProperties\": {\n    \"key_0\": \"<string>\",\n    \"key_1\": \"<string>\",\n    \"key_2\": \"<string>\",\n    \"key_3\": \"<string>\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
