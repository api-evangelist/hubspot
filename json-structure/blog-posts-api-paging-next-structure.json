{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/blog-posts-api-paging-next-structure.json",
  "name": "PagingNext",
  "description": "Pagination cursor for next page",
  "type": "object",
  "properties": {
    "after": {
      "type": "string",
      "description": "Cursor token for the next page",
      "example": "example-value"
    },
    "link": {
      "type": "string",
      "description": "API link to the next page",
      "example": "https://app.hubspot.com/contacts/12345"
    }
  }
}