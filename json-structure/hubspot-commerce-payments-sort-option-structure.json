{
  "type": "object",
  "description": "A sort option for ordering results",
  "name": "SortOption",
  "properties": {
    "propertyName": {
      "type": "string",
      "description": "The property to sort by"
    },
    "direction": {
      "type": "string",
      "description": "The sort direction",
      "enum": [
        "ASCENDING",
        "DESCENDING"
      ]
    }
  },
  "required": [
    "propertyName",
    "direction"
  ],
  "$schema": "https://json-structure.org/draft/2020-12/schema"
}