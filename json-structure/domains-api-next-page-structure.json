{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/domains-api-next-page-structure.json",
  "name": "NextPage",
  "description": "Information about the next page of results",
  "type": "object",
  "properties": {
    "after": {
      "type": "string",
      "description": "The cursor token for the next page",
      "example": "NTI1Cg%3D%3D"
    },
    "link": {
      "type": "string",
      "description": "A direct link to the next page",
      "example": "?after=NTI1Cg%3D%3D"
    }
  },
  "required": [
    "after"
  ]
}