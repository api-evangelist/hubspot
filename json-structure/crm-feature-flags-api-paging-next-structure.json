{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/crm-feature-flags-api-paging-next-structure.json",
  "name": "PagingNext",
  "description": "Information for fetching the next page of results",
  "type": "object",
  "properties": {
    "after": {
      "type": "string",
      "description": "Cursor for the next page",
      "example": "NTI1Cg%3D%3D"
    },
    "link": {
      "type": "string",
      "description": "Direct link to the next page",
      "example": "https://api.hubapi.com/feature-flags/v3/12345678/flags/new-dashboard-feature/portals?after=NTI1Cg%3D%3D"
    }
  },
  "required": [
    "after"
  ]
}