{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/marketing-emal-api-transactional-email-response-structure.json",
  "name": "TransactionalEmailResponse",
  "description": "Response after sending a transactional email",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "PENDING",
        "PROCESSING",
        "CANCELED",
        "COMPLETE"
      ],
      "description": "The status of the email send",
      "example": "PENDING"
    },
    "statusId": {
      "type": "string",
      "description": "A unique identifier for tracking the email status",
      "example": "status-id-abc123"
    },
    "sendResult": {
      "type": "string",
      "description": "Additional details about the send result",
      "example": "SENT"
    },
    "requestedAt": {
      "type": "datetime",
      "description": "When the send was requested",
      "example": "2025-03-15T14:30:00Z"
    },
    "startedAt": {
      "type": "datetime",
      "description": "When the send processing started",
      "example": "2025-03-15T14:30:00Z"
    },
    "completedAt": {
      "type": "datetime",
      "description": "When the send processing completed",
      "example": "2025-03-15T14:30:00Z"
    }
  },
  "required": [
    "status",
    "statusId"
  ]
}