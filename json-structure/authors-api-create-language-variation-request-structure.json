{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/authors-api-create-language-variation-request-structure.json",
  "name": "CreateLanguageVariationRequest",
  "description": "Request to create a language variation of an author",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "ID of the source author",
      "example": "500123"
    },
    "language": {
      "type": "string",
      "description": "Language code for the new variation",
      "example": "en"
    }
  },
  "required": [
    "id",
    "language"
  ]
}