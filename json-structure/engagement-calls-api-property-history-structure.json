{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/engagement-calls-api-property-history-structure.json",
  "name": "PropertyHistory",
  "description": "Historical value of a property",
  "type": "object",
  "properties": {
    "value": {
      "type": "string",
      "description": "The historical value",
      "example": "Discovery Call"
    },
    "timestamp": {
      "type": "datetime",
      "description": "When the value was set",
      "example": "2024-01-15T10:30:00.000Z"
    },
    "sourceType": {
      "type": "string",
      "description": "The source type that set this value",
      "example": "CRM_UI"
    },
    "sourceId": {
      "type": "string",
      "description": "The source identifier",
      "example": "userId:12345"
    },
    "sourceLabel": {
      "type": "string",
      "description": "Human-readable source label",
      "example": "John Doe"
    },
    "updatedByUserId": {
      "type": "int32",
      "description": "The user ID who made the change",
      "example": 12345
    }
  }
}