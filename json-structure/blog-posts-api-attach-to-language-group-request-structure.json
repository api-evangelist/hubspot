{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/blog-posts-api-attach-to-language-group-request-structure.json",
  "name": "AttachToLanguageGroupRequest",
  "description": "Request to attach to language group",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "ID of the post to attach",
      "example": "500123"
    },
    "language": {
      "type": "string",
      "description": "Language code for the post",
      "example": "en"
    },
    "primaryId": {
      "type": "string",
      "description": "ID of the primary language post",
      "example": "500123"
    },
    "primaryLanguage": {
      "type": "string",
      "description": "Language code of the primary post",
      "example": "en"
    }
  },
  "required": [
    "id",
    "language",
    "primaryId"
  ]
}