{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/crm-deals-api-collection-response-association-structure.json",
  "name": "CollectionResponseAssociation",
  "description": "A list of associations.",
  "type": "object",
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "An association between two CRM objects.",
        "properties": {
          "id": {
            "type": "string",
            "example": "500123"
          },
          "type": {
            "type": "string",
            "example": "standard"
          }
        }
      },
      "example": [
        {
          "id": "500123",
          "type": "standard"
        }
      ]
    },
    "paging": {
      "type": "object",
      "description": "Pagination information.",
      "properties": {
        "next": {
          "type": "object",
          "properties": {
            "after": {
              "type": "string"
            }
          },
          "example": {
            "after": "example-value"
          }
        }
      }
    }
  }
}