{
  "type": "object",
  "description": "Pagination information",
  "name": "Paging",
  "properties": {
    "next": {
      "type": "object",
      "description": "Information about the next page",
      "properties": {
        "after": {
          "type": "string",
          "description": "Cursor for the next page"
        },
        "link": {
          "type": "string",
          "description": "Link to the next page"
        }
      },
      "required": [
        "after"
      ]
    }
  },
  "$schema": "https://json-structure.org/draft/2020-12/schema"
}