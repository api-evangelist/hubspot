{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/conversations-api-paging-structure.json",
  "name": "Paging",
  "description": "Pagination information for list responses.",
  "type": "object",
  "properties": {
    "next": {
      "type": "object",
      "description": "Pagination cursor information for retrieving the next page.",
      "properties": {
        "after": {
          "type": "string",
          "description": "Cursor token for the next page",
          "example": "NTI1Cg%3D%3D"
        },
        "link": {
          "type": "string",
          "description": "API link to the next page",
          "example": "/conversations/v3/conversations/inboxes?after=NTI1Cg%3D%3D"
        }
      }
    }
  }
}