{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/commerce-payments-api-association-type-structure.json",
  "name": "AssociationType",
  "description": "An association type definition",
  "type": "object",
  "properties": {
    "associationCategory": {
      "type": "string",
      "enum": [
        "HUBSPOT_DEFINED",
        "USER_DEFINED",
        "INTEGRATOR_DEFINED"
      ],
      "description": "The category of the association",
      "example": "HUBSPOT_DEFINED"
    },
    "associationTypeId": {
      "type": "int32",
      "description": "The numeric ID of the association type",
      "example": 500123
    }
  },
  "required": [
    "associationCategory",
    "associationTypeId"
  ]
}