{
  "type": "object",
  "description": "Input for batch read operations",
  "name": "BatchReadInput",
  "properties": {
    "inputs": {
      "type": "array",
      "description": "Array of author IDs to retrieve",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID of the author to read"
          }
        },
        "required": [
          "id"
        ]
      }
    }
  },
  "required": [
    "inputs"
  ],
  "$schema": "https://json-structure.org/draft/2020-12/schema"
}