{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/blog-posts-api-restore-previous-version-request-structure.json",
  "name": "RestorePreviousVersionRequest",
  "description": "Request to restore a previous version",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "ID of the blog post",
      "example": "500123"
    },
    "revisionId": {
      "type": "string",
      "description": "ID of the revision to restore",
      "example": "500123"
    }
  },
  "required": [
    "id",
    "revisionId"
  ]
}