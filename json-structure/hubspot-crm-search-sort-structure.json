{
  "type": "object",
  "description": "A sort criterion for ordering search results.",
  "name": "Sort",
  "properties": {
    "propertyName": {
      "type": "string",
      "description": "The name of the CRM property to sort by."
    },
    "direction": {
      "type": "string",
      "description": "The sort direction.",
      "enum": [
        "ASCENDING",
        "DESCENDING"
      ]
    }
  },
  "required": [
    "propertyName"
  ],
  "$schema": "https://json-structure.org/draft/2020-12/schema"
}