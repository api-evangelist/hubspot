{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/blog-posts-api-schedule-request-structure.json",
  "name": "ScheduleRequest",
  "description": "Request to schedule a blog post for publication",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "ID of the blog post to schedule",
      "example": "500123"
    },
    "publishDate": {
      "type": "datetime",
      "description": "ISO 8601 date and time to publish",
      "example": "2025-03-15T14:30:00Z"
    }
  },
  "required": [
    "id",
    "publishDate"
  ]
}