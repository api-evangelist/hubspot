{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/crm-contacts-api-batch-read-input-structure.json",
  "name": "BatchReadInput",
  "description": "Input for a batch read operation.",
  "type": "object",
  "properties": {
    "properties": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "The properties to return for each record.",
      "example": [
        "example-value"
      ]
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        }
      },
      "description": "The IDs of the records to read.",
      "example": [
        {
          "id": "500123"
        }
      ]
    }
  }
}