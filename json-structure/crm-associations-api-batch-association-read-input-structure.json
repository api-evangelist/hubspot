{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/crm-associations-api-batch-association-read-input-structure.json",
  "name": "BatchAssociationReadInput",
  "description": "Input for batch reading associations",
  "type": "object",
  "properties": {
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "Reference to a CRM object by ID",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID of the object",
            "example": "500123"
          }
        },
        "required": [
          "id"
        ]
      },
      "description": "Source objects to read associations for",
      "example": [
        {
          "id": "500123"
        }
      ]
    }
  },
  "required": [
    "inputs"
  ]
}