{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/blog-posts-api-paging-previous-structure.json",
  "name": "PagingPrevious",
  "description": "Pagination cursor for previous page",
  "type": "object",
  "properties": {
    "before": {
      "type": "string",
      "description": "Cursor token for the previous page",
      "example": "example-value"
    },
    "link": {
      "type": "string",
      "description": "API link to the previous page",
      "example": "https://app.hubspot.com/contacts/12345"
    }
  }
}