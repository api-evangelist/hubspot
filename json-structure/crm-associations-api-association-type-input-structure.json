{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hubspot/refs/heads/main/json-structure/crm-associations-api-association-type-input-structure.json",
  "name": "AssociationTypeInput",
  "description": "Input for specifying an association type",
  "type": "object",
  "properties": {
    "associationCategory": {
      "type": "string",
      "enum": [
        "HUBSPOT_DEFINED",
        "USER_DEFINED",
        "INTEGRATOR_DEFINED"
      ],
      "example": "HUBSPOT_DEFINED"
    },
    "associationTypeId": {
      "type": "int32",
      "example": 500123
    }
  },
  "required": [
    "associationCategory",
    "associationTypeId"
  ]
}