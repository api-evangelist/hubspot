      "@id": "hubspot:text",
      "@type": "xsd:string"
    },
    "richText": {
      "@id": "hubspot:richText",
      "@type": "xsd:string"
    },
    "direction": {
      "@id": "hubspot:direction",
      "@type": "xsd:string"
    },
    "channelId": {
      "@id": "hubspot:channelId",
      "@type": "xsd:string"
    },
    "channelAccountId": {
      "@id": "hubspot:channelAccountId",
      "@type": "xsd:string"
    },
    "senders": {
      "@id": "hubspot:senders",
