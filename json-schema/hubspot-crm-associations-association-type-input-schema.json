{
  "type": "object",
  "description": "Input for specifying an association type",
  "properties": {
    "associationCategory": {
      "type": "string",
      "example": "HUBSPOT_DEFINED",
      "enum": [
        "HUBSPOT_DEFINED",
        "USER_DEFINED",
        "INTEGRATOR_DEFINED"
      ]
    },
    "associationTypeId": {
      "type": "integer",
      "example": 500123
    }
  },
  "required": [
    "associationCategory",
    "associationTypeId"
  ],
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssociationTypeInput"
}