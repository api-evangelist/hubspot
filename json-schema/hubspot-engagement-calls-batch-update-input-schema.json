{
  "type": "object",
  "description": "Input for updating a single item in a batch",
  "properties": {
    "id": {
      "type": "string",
      "description": "The call identifier",
      "example": "512"
    },
    "properties": {
      "type": "object",
      "description": "The properties to update",
      "example": {
        "key": "value"
      }
    }
  },
  "required": [
    "id",
    "properties"
  ],
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BatchUpdateInput"
}