{
  "type": "object",
  "description": "Sort option for search results",
  "properties": {
    "propertyName": {
      "type": "string",
      "description": "The property to sort by",
      "example": "hs_timestamp"
    },
    "direction": {
      "type": "string",
      "description": "Sort direction",
      "example": "DESCENDING",
      "enum": [
        "ASCENDING",
        "DESCENDING"
      ]
    }
  },
  "required": [
    "propertyName"
  ],
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SortOption"
}