{
  "type": "object",
  "description": "A sort option for ordering results",
  "properties": {
    "propertyName": {
      "type": "string",
      "description": "The property to sort by",
      "example": "Example Record"
    },
    "direction": {
      "type": "string",
      "description": "The sort direction",
      "example": "ASCENDING",
      "enum": [
        "ASCENDING",
        "DESCENDING"
      ]
    }
  },
  "required": [
    "propertyName",
    "direction"
  ],
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SortOption"
}