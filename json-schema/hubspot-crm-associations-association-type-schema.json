{
  "type": "object",
  "description": "Defines the type of association",
  "properties": {
    "associationCategory": {
      "type": "string",
      "description": "Category of the association type",
      "example": "HUBSPOT_DEFINED",
      "enum": [
        "HUBSPOT_DEFINED",
        "USER_DEFINED",
        "INTEGRATOR_DEFINED"
      ]
    },
    "associationTypeId": {
      "type": "integer",
      "description": "Numeric identifier for the association type",
      "example": 500123
    },
    "label": {
      "type": "string",
      "description": "Human-readable label for the association",
      "example": "Example Record"
    }
  },
  "required": [
    "associationCategory",
    "associationTypeId"
  ],
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssociationType"
}