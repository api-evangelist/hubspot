{
  "type": "object",
  "description": "A HubSpot meeting engagement record.",
  "properties": {
    "id": {
      "type": "string",
      "description": "The unique identifier for the meeting.",
      "example": "500123"
    },
    "properties": {
      "type": "object",
      "description": "The meeting's properties as key-value pairs.",
      "example": {
        "key": "value"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "example": "2025-03-15T14:30:00Z"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "example": "2025-03-15T14:30:00Z"
    },
    "archived": {
      "type": "boolean",
      "example": true
    },
    "associations": {
      "type": "object",
      "example": {
        "key": "value"
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Meeting"
}