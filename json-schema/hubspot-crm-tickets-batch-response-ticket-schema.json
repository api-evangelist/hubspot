{
  "type": "object",
  "description": "Results from a batch operation on tickets.",
  "properties": {
    "status": {
      "type": "string",
      "example": "active"
    },
    "results": {
      "type": "array",
      "example": [
        {
          "id": "500123",
          "properties": {
            "key": "value"
          },
          "createdAt": "2025-03-15T14:30:00Z",
          "updatedAt": "2025-03-15T14:30:00Z",
          "archived": true,
          "associations": {
            "key": "value"
          }
        }
      ],
      "items": {
        "type": "object",
        "description": "A HubSpot ticket record.",
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique identifier for the ticket.",
            "example": "500123"
          },
          "properties": {
            "type": "object",
            "description": "The ticket's properties as key-value pairs.",
            "example": {
              "key": "value"
            }
          },
          "createdAt": {
            "type": "string",
            "description": "The date and time the ticket was created.",
            "format": "date-time",
            "example": "2025-03-15T14:30:00Z"
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time the ticket was last updated.",
            "format": "date-time",
            "example": "2025-03-15T14:30:00Z"
          },
          "archived": {
            "type": "boolean",
            "description": "Whether the ticket has been archived.",
            "example": true
          },
          "associations": {
            "type": "object",
            "description": "The ticket's associations with other CRM objects.",
            "example": {
              "key": "value"
            }
          }
        }
      }
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "example": "2025-03-15T14:30:00Z"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BatchResponseTicket"
}