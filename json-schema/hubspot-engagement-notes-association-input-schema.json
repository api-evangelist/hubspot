{
  "type": "object",
  "description": "Association to create with another object",
  "properties": {
    "to": {
      "type": "object",
      "example": {
        "id": "101"
      },
      "properties": {
        "id": {
          "type": "string",
          "description": "The ID of the object to associate with",
          "example": "101"
        }
      },
      "required": [
        "id"
      ]
    },
    "types": {
      "type": "array",
      "description": "The association types",
      "example": [
        {
          "associationCategory": "HUBSPOT_DEFINED",
          "associationTypeId": 202
        }
      ],
      "items": {
        "type": "object",
        "description": "Type of association",
        "properties": {
          "associationCategory": {
            "type": "string",
            "description": "The category of association",
            "example": "HUBSPOT_DEFINED",
            "enum": [
              "HUBSPOT_DEFINED",
              "USER_DEFINED",
              "INTEGRATOR_DEFINED"
            ]
          },
          "associationTypeId": {
            "type": "integer",
            "description": "The association type ID",
            "example": 202
          }
        },
        "required": [
          "associationCategory",
          "associationTypeId"
        ]
      }
    }
  },
  "required": [
    "to",
    "types"
  ],
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssociationInput"
}